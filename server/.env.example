# Server
PORT=3001
NODE_ENV=development

# MongoDB
MONGODB_URI=mongodb+srv://<username>:<password>@cluster.mongodb.net/local-sm?retryWrites=true&w=majority

# JWT
JWT_ACCESS_SECRET=your-access-secret-min-64-chars-long-replace-this-immediately
JWT_REFRESH_SECRET=your-refresh-secret-min-64-chars-long-replace-this-immediately
JWT_ACCESS_EXPIRES=15m
JWT_REFRESH_EXPIRES=7d

# Client URL (CORS)
CLIENT_URL=http://localhost:3000

# Email (Nodemailer)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your-email@gmail.com
SMTP_PASS=your-app-password

# Super Admin (seed)
SUPER_ADMIN_EMAIL=admin@localsm.com
SUPER_ADMIN_PASSWORD=Admin@123456
